{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Spring Boot Run",
      "type": "shell",
      "command": "mvn spring-boot:run",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Local Server",
      "type": "shell",
      "command": "python3 -m http.server 5500",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    }
  ]
}
